# Forge CLI credentials (used for non-interactive `forge login`)
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
#
# Create an API token at: https://id.atlassian.com/manage-profile/security/api-tokens
#
# Usage:
#   set -a && source .env && set +a
#   forge login --non-interactive

FORGE_EMAIL=you@example.com
FORGE_API_TOKEN=your_atlassian_api_token_here

# API E2E test (`npm run test:e2e`) — drives the real backend REST calls against
# a live site using the API token above (HTTP Basic auth).
# ⚠️ DESTRUCTIVE: it deletes + recreates E2E_PROJECT_KEY from scratch each run,
# so use a DEDICATED disposable key (never your real KPI space). The token needs
# Jira admin rights (project create/delete + issue-type scheme management).
JIRA_BASE_URL=https://bitovi-training.atlassian.net
E2E_PROJECT_KEY=MOSE2E
